##PHASE 2 — Mount Installation Media & Configure Local Repo (as root)

  mkdir -p /localdvd
  --now move iso file this location by winScn

  vi /etc/yum.repos.d/local.repo
[local]
name=LocalRepository
baseurl=file:///localdvd
enabled=1
gpgcheck=0
#gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-CentOS-7

 cat /etc/yum.repos.d/local.repo


 --now go this directory and past this

 cd /localdvd
 mount -o loop /localdvd/rhel-server-7.9-x86_64-dvd.iso /localdvd


--Test the repo:

yum clean all
yum repolist



## PHASE 3 — Install Required OS Packages (as root)

yum install -y bc binutils elfutils-libelf fontconfig glibc glibc-devel glibc-headers ksh libaio libX11 libXau libXi libXrender libXtst libgcc libibverbs librdmacm libstdc++ libxcb libvirt-libs make policycoreutils policycoreutils-python smartmontools sysstat net-tools nfs-utils xorg-x11-xauth




## PHASE 4 — Kernel Parameters (as root)

vi /etc/sysctl.d/98-oracle.conf
Press i, then paste

fs.file-max = 6815744
kernel.sem = 250 32000 100 128
kernel.shmmni = 4096
kernel.shmall = 1073741824
kernel.shmmax = 4398046511104
kernel.panic_on_oops = 1
net.core.rmem_default = 262144
net.core.rmem_max = 4194304
net.core.wmem_default = 262144
net.core.wmem_max = 1048576
net.ipv4.conf.all.rp_filter = 2
net.ipv4.conf.default.rp_filter = 2
fs.aio-max-nr = 1048576
net.ipv4.ip_local_port_range = 9000 65500

Press Esc, then type

:wq!

and press Enter

--Verify the file saved correctly

cat /etc/sysctl.d/98-oracle.conf

--or

cat >> /etc/sysctl.conf << 'EOF'
fs.file-max = 6815744
kernel.sem = 250 32000 100 128
kernel.shmmni = 4096
kernel.shmall = 1073741824
kernel.shmmax = 4398046511104
kernel.panic_on_oops = 1
net.core.rmem_default = 262144
net.core.rmem_max = 4194304
net.core.wmem_default = 262144
net.core.wmem_max = 1048576
net.ipv4.conf.all.rp_filter = 2
net.ipv4.conf.default.rp_filter = 2
fs.aio-max-nr = 1048576
net.ipv4.ip_local_port_range = 9000 65500
EOF


/sbin/sysctl -p

```

Verify values applied:
```bash
sysctl -a | grep -E 'shmmax|shmall|file-max|aio-max-nr'

```

##PHASE  5 — Apply the settings to the running kernel

  /sbin/sysctl -p /etc/sysctl.d/98-oracle.conf



