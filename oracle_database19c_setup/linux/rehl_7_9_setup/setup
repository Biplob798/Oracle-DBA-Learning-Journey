## PHASE 7 — Create Groups, User, and Directories (as root)


groupadd -g 54321 oinstall
groupadd -g 54322 dba
groupadd -g 54323 oper
useradd -u 54321 -g oinstall -G dba,oper oracle
passwd oracle


--Verify
id oracle



mkdir -p /u01/app/oracle/product/19.0.0/dbhome_1
mkdir -p /u01/app/oracle/oradata
mkdir -p /home/oracle/scripts

chown -R oracle:oinstall /u01
chmod -R 775 /u01
 
chown -R oracle:oinstall /u01/app/oracle/oradata
chmod -R 775 /u01/app/oracle/oradata



## PHASE 7 — Disable SELinux & Firewall (as root, optional but recommended for smooth install)


systemctl stop firewalld
systemctl disable firewalld

setenforce 0

vi /etc/selinux/config

--Press i to enter insert mode

SELINUX=permissive

--Press Esc, then type :wq! and press Enter to save.

getenforce
cat /etc/selinux/config | grep ^SELINUX=

--or

sed -i 's/^SELINUX=.*/SELINUX=permissive/' /etc/selinux/config


## PHASE 8 — Stage the Oracle Zip File for the Oracle User (as root)

--Copy the Oracle database zip file to the (/u01/app/oracle/product/19.0.0/dbhome_1) by WinScn and hand ownership to oracle immediately:

chown oracle:oinstall /u01/app/oracle/product/19.0.0/dbhome_1/LINUX.X64_193000_db_home.zip

## PHASE 9 — Connect as `oracle` Directly via SSH (Critical for Display to Work)

Instead, open a **brand-new SSH session logging in as `oracle` directly**:

1. In MobaXterm: **Sessions → New session → SSH**
2. Remote host: your server's IP address
3. Check "Specify username" → enter `oracle`
4. Click the **"Advanced SSH settings"** tab
5. Check ✅ **"X11-Forwarding"**
6. Click **OK** and log in with the oracle password 


export CV_ASSUME_DISTID=OEL7.6
echo $DISPLAY
xdpyinfo

echo $DISPLAY


## PHASE 10 — Set Environment Variables Permanently (as oracle) 
--all do in (ROOT User)

cat > /home/oracle/scripts/setEnv.sh <<EOF
export TMP=/tmp
export TMPDIR=\$TMP

export ORACLE_HOSTNAME=localhost.localdomain
export ORACLE_UNQNAME=dblcluster
export ORACLE_BASE=/u01/app/oracle
export ORACLE_HOME=\$ORACLE_BASE/product/19.0.0/dbhome_1
export ORA_INVENTORY=/u01/app/oraInventory
export ORACLE_SID=dblclustersid
export DATA_DIR=/u01/app/oracle/oradata

export PATH=/usr/sbin:/usr/local/bin:\$PATH
export PATH=\$ORACLE_HOME/bin:\$PATH

export LD_LIBRARY_PATH=\$ORACLE_HOME/lib:/lib:/usr/lib
export CLASSPATH=\$ORACLE_HOME/jlib:\$ORACLE_HOME/rdbms/jlib
EOF


cat > /home/oracle/scripts/start_all.sh <<EOF
. /home/oracle/scripts/setEnv.sh

export ORAENV_ASK=NO
. oraenv
export ORAENV_ASK=YES

dbstart \$ORACLE_HOME
EOF


cat > /home/oracle/scripts/stop_all.sh <<EOF
. /home/oracle/scripts/setEnv.sh

export ORAENV_ASK=NO
. oraenv
export ORAENV_ASK=YES

dbshut \$ORACLE_HOME
EOF


chown -R oracle:oinstall /home/oracle/scripts
chmod u+x /home/oracle/scripts/*.sh

echo ". /home/oracle/scripts/setEnv.sh" >> /home/oracle/.bash_profile

PHASE 11 — Verify Environment (as oracle)

echo $ORACLE_HOME
echo $ORACLE_SID
echo $ORACLE_HOSTNAME
echo $DATA_DIR

