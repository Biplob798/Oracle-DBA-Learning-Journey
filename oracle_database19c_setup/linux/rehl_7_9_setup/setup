/u01/app/oraInventory/orainstRoot.sh
/u01/app/oracle/product/19.0.0/dbhome_1/root.sh


## PHASE 13 — Create a Database with DBCA


export CV_ASSUME_DISTID=OEL7.6
cd $ORACLE_HOME/bin
./dbca


## PHASE 14 — Connect to the Database


export ORACLE_SID=dblcluster
sqlplus / as sysdba

ALTER USER HR IDENTIFIED BY hr ACCOUNT UNLOCK;

sqlplus HR/hr@dblcluster


Step 1 — Check if you actually have a CDB/PDB setup

sqlplus / as sysdba

SELECT name, cdb FROM v$database;


Step 2 — List the pluggable databases

SHOW PDBS;


Step 3 — Switch your session into that PDB

ALTER SESSION SET CONTAINER = ORCLPDB;

Step 4 — Now unlock/set up HR inside the PDB

SELECT username, account_status FROM dba_users WHERE username='HR';

ALTER USER HR IDENTIFIED BY hr ACCOUNT UNLOCK;

Step 5 — Exit and connect directly to the PDB as HR

SHOW CON_NAME;

sqlplus HR/hr@localhost:1521/ORCLPDB


--for if hr schema not exit---

Step 1: Allow local users in the CDB Root
SQL
-- Reconnect as SYS if you aren't already
conn / as sysdba

-- Enable traditional user creation in a CDB
ALTER SESSION SET "_oracle_script"=true;
Step 2: Run the Official HR Installation Script
Now, run the built-in script. The ? symbol is a shortcut that points straight to your Oracle Home path:

SQL
@?/demo/schema/human_resources/hr_main.sql
⌨️ What to Type When the Script Prompts You:
The script will stop and ask you for 4 specific parameters. Type them out and hit Enter for each one:

specify password for HR as parameter 1: Type hr

specify default tablespace for HR as parameter 2: Type users

specify temporary tablespace for HR as parameter 3: Type temp

specify log path as parameter 4: Type /tmp/

🧪 Test Your New HR Connection
Once the script finishes running and creating all the tables, test your connection way:

SQL
conn hr/hr
It will now cleanly report Connected. and you can run select * from tab; to see your new sample tables! Let me know if the @? script execution starts up smoothly on your screen.